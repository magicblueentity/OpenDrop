<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OpenDrop.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:vm="using:OpenDrop.App.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop" Padding="24" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="Nearby" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="{Binding StatusText}" Opacity="0.7" />
        </StackPanel>

        <GridView
            Grid.Row="1"
            ItemsSource="{Binding Devices}"
            IsItemClickEnabled="True"
            ItemClick="OnDeviceItemClick"
            SelectionMode="None"
            HorizontalAlignment="Stretch">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="vm:DeviceViewModel">
                    <Border
                        CornerRadius="14"
                        Padding="14"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel Spacing="8" Width="170">
                            <Grid>
                                <Ellipse Width="56" Height="56" Fill="{ThemeResource SystemFillColorNeutralBackgroundBrush}" />
                                <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}" Margin="0,64,0,0" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind ServiceHost, Mode=OneWay}" Opacity="0.6" FontSize="12" TextTrimming="CharacterEllipsis" />
                            </Grid>
                            <TextBlock Text="{x:Bind IsSelected, Mode=OneWay}" Opacity="0.0" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <Border Grid.Row="2" CornerRadius="14" Padding="16" Background="{ThemeResource AccentFillColorSecondaryBrush}">
            <TextBlock Text="Drag files here to send to the selected device." />
        </Border>
    </Grid>
</Page>
